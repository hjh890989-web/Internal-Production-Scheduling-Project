# =============================================================================
# infrastructure/.env.prod.example — PROD 환경 변수 템플릿
# =============================================================================
# 실제 .env.prod 는 git ignore (rule: infrastructure/.env.*).
# 모든 <vault> 자리는 사내 vault (HashiCorp Vault / 1Password Connect / Doppler) 에서 주입.
# 평문 PROD 비밀 파일 금지 — DLP 정책 (NFR-SEC-005).
#
# 사용 (PROD 서버에서):
#   sudo cp .env.prod.example /opt/scheduling/infrastructure/.env.prod
#   sudo chmod 600 /opt/scheduling/infrastructure/.env.prod
#   # vault 에서 <vault> 자리 채움 (vault read secret/scheduling/prod)
#
# 분기별 rotation 의무: POSTGRES_PASSWORD, KEYCLOAK_*_PASSWORD, BACKUP_ENCRYPTION_KEY,
#                       SLACK_WEBHOOK_URL, SENTRY_DSN — secrets-management.md §rotation
# =============================================================================

# ---------- PostgreSQL (운영 DB) ----------
POSTGRES_DB=scheduling
POSTGRES_USER=app_user
POSTGRES_PASSWORD=<vault — secret/scheduling/prod/db_password>

# ---------- Redis ----------
REDIS_PASSWORD=<vault — secret/scheduling/prod/redis_password>

# ---------- Backend (Spring Boot) ----------
HARBOR_REGISTRY=harbor.internal/scheduling
TAG_BLUE=v1.0.0                          # 초기 PROD release
TAG_GREEN=v1.0.0                         # 첫 부팅 동일, 다음 배포부터 toggle
SPRING_PROFILES_ACTIVE=prod,with-infra
JAVA_OPTS=-Xms1g -Xmx4g

# ---------- Keycloak 24 LTS ----------
KEYCLOAK_HOST=scheduling.internal
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<vault — secret/scheduling/prod/keycloak_admin>
KEYCLOAK_DB_PASSWORD=<vault — secret/scheduling/prod/keycloak_db>

# Keycloak Jenkins client secret (Sprint 1+ EP-30 활성 후)
# KEYCLOAK_JENKINS_SECRET=<vault — secret/scheduling/prod/keycloak_jenkins>

# ---------- Backup (TK-33-2-1·TK-41-4-1 cron) ----------
BACKUP_BUCKET=s3://internal-backup/scheduling      # 또는 사내 NAS (nfs:// 또는 cifs://)
BACKUP_ENCRYPTION_KEY=<vault — secret/scheduling/prod/backup_aes>
BACKUP_RETENTION_DAYS=30                  # NFR-REL-005

# ---------- 알림 (Sprint 1+ EP-44 ST-44-3) ----------
SLACK_WEBHOOK_URL=<vault — secret/scheduling/prod/slack_webhook>
SLACK_CHANNEL=#scheduling-prod-alerts

# ---------- 관측성·APM (Sprint 1+ EP-31·EP-44) ----------
SENTRY_DSN=<vault — secret/scheduling/prod/sentry_dsn>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1            # 10% sampling (성능 영향 ↓)

# ---------- NGINX ----------
SERVER_NAME=scheduling.internal
# PROD ports 0.0.0.0:80,443 (사내 firewall 로 사내 IP whitelist)
