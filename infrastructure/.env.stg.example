# =============================================================================
# infrastructure/.env.stg.example — STG 환경 변수 템플릿
# =============================================================================
# 실제 .env.stg 는 git ignore (rule: infrastructure/.env.*).
# 사내 vault 또는 secret manager 에서 주입.
# =============================================================================

# ---------- PostgreSQL (STG DB 분리) ----------
POSTGRES_DB=scheduling_stg
POSTGRES_USER=app_user
POSTGRES_PASSWORD=<vault — STG 전용, PROD 와 별도>

# ---------- Redis ----------
REDIS_PASSWORD=<vault>

# ---------- Backend ----------
HARBOR_REGISTRY=harbor.internal/scheduling
TAG=latest                              # 또는 git-sha (예: develop-3ab2f1c)
SPRING_PROFILES_ACTIVE=stg,with-infra
JAVA_OPTS=-Xms512m -Xmx2g

# ---------- Keycloak (STG 전용 realm 권장 또는 PROD realm 공용) ----------
KEYCLOAK_HOST=stg.scheduling.internal
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<vault>
KEYCLOAK_DB_PASSWORD=<vault>

# ---------- Grafana 10.4 (TK-31-1-3) ----------
GRAFANA_ADMIN=admin
GRAFANA_ADMIN_PASSWORD=<vault>

# ---------- NGINX ----------
SERVER_NAME=stg.scheduling.internal
