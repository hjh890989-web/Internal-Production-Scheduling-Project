{
  "uid": "scheduling-app-overview",
  "title": "Application Overview — Backend RED metrics",
  "tags": ["scheduling", "application", "red"],
  "timezone": "Asia/Seoul",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate (req/s) — by URI",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (uri) (scheduling:http_requests:rate5m)", "refId": "A", "legendFormat": "{{uri}}" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 5xx error rate — by URI",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "scheduling:http_errors:rate5m", "refId": "A", "legendFormat": "{{uri}}" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP latency p95 — by URI",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "scheduling:http_latency_p95:5m", "refId": "A", "legendFormat": "{{uri}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Application started time (s)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "application_started_time_seconds{service=\"backend\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "JVM threads",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "jvm_threads_live_threads{service=\"backend\"}", "refId": "A" }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "GC pause time p99",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum by (le) (rate(jvm_gc_pause_seconds_bucket{service=\"backend\"}[5m])))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Custom scheduling.duration p95 (BR-X01·X07 후행)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, module, operation) (rate(scheduling_duration_seconds_bucket[5m])))", "refId": "A", "legendFormat": "{{module}}/{{operation}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
