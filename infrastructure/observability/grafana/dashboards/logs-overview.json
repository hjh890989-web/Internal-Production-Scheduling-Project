{
  "uid": "scheduling-logs-overview",
  "title": "Logs Overview — 모든 컨테이너 (Loki)",
  "tags": ["scheduling", "logs", "loki"],
  "timezone": "Asia/Seoul",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(service)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "level",
        "type": "custom",
        "query": "ERROR,WARN,INFO,DEBUG",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "ERROR + WARN", "value": ["ERROR", "WARN"] }
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "최근 로그 (service: $service, level: $level)",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "{service=~\"$service\"} | json | level=~\"$level\"",
        "refId": "A"
      }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "로그 rate (per service)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (service) (rate({service=~\"$service\"}[5m]))",
        "refId": "A",
        "legendFormat": "{{service}}"
      }],
      "fieldConfig": { "defaults": { "unit": "logs/s" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "ERROR rate (per service)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (service) (rate({service=~\"$service\"} | json | level=\"ERROR\" [5m]))",
        "refId": "A",
        "legendFormat": "{{service}}"
      }],
      "fieldConfig": { "defaults": { "unit": "logs/s", "color": { "mode": "fixed", "fixedColor": "red" } } }
    }
  ]
}
