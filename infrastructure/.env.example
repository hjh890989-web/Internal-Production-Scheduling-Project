# =============================================================================
# infrastructure/.env.example
# =============================================================================
# 실제 .env 는 git ignore (.gitignore 의 '.env' 룰).
# PROD 패스워드는 사내 vault/secret manager 에서 주입 — 본 파일은 템플릿만.
# 패스워드 규칙: 12자+ 3종 혼합 (영문대소·숫자·특수문자) — NFR-SEC-007.
# =============================================================================

# ---------- PostgreSQL (TK-00-1-1) ----------
POSTGRES_DB=scheduling
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme_in_actual_env_at_least_12_chars

# ---------- Redis (TK-00-1-2) ----------
REDIS_PASSWORD=changeme_redis_at_least_12_chars

# ---------- Backend (Sprint 1+ TK-00-1-4 통합 후) ----------
SPRING_PROFILES_ACTIVE=dev
JAVA_OPTS=-Xms512m -Xmx2g

# ---------- NGINX (TK-00-1-3) ----------
# DEV 포트는 docker-compose.yml 에서 127.0.0.1:80, 127.0.0.1:443 고정.
# STG/PROD 는 docker-compose.{staging,prod}.yml 별도 override.

# ---------- Keycloak 24 LTS (TK-30-1-1) ----------
KEYCLOAK_HOST=localhost
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_kc_admin_at_least_12_chars
KEYCLOAK_DB_PASSWORD=changeme_kc_db_at_least_12_chars
