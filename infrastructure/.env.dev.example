# =============================================================================
# infrastructure/.env.dev.example — DEV 환경 변수 템플릿
# =============================================================================
# 실제 .env (또는 .env.dev) 는 git ignore. DEV 한정 — 사내 vault 미사용,
# 개발자 PC 평문 .env 사용 (chmod 600 권장).
# 패스워드 규칙: 12자+ 3종 혼합 (NFR-SEC-007) — DEV 도 동일 정책 권장 (검증 목적).
#
# 사용:
#   cp .env.dev.example .env
#   # 또는 .env.dev (compose --env-file .env.dev)
# =============================================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=scheduling
POSTGRES_USER=app_user
POSTGRES_PASSWORD=Dev_Pg_Local_2026

# ---------- Redis ----------
REDIS_PASSWORD=Dev_Redis_Local_2026

# ---------- Backend ----------
SPRING_PROFILES_ACTIVE=dev
JAVA_OPTS=-Xms512m -Xmx2g

# ---------- NGINX ----------
# DEV 포트는 docker-compose.yml 에서 127.0.0.1:80, 127.0.0.1:443 고정.

# ---------- Keycloak 24 LTS ----------
KEYCLOAK_HOST=localhost
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=Dev_Kc_Admin_2026
KEYCLOAK_DB_PASSWORD=Dev_Kc_Db_2026

# ---------- Grafana 10.4 (TK-31-1-3) ----------
GRAFANA_ADMIN=admin
GRAFANA_ADMIN_PASSWORD=Dev_Grafana_Admin_2026
