# =============================================================================
# Internal Production Scheduling Project — .gitignore
# =============================================================================

# -------- 대화기록 정책 (2026-05-15 사용자 결정) --------
# 0.Prompt/ 폴더는 git에 commit (.gitignore 처리 안 함).
# 대화기록(대화기록_YYYY-MM-DD.md)은 인계·감사·복기 목적으로 저장소에 보존.
# ※ 민감정보(secrets·credentials·개인정보)는 본 폴더에 절대 저장 금지 —
#   commit 전 검토 필수.

# -------- Excel / Office 임시 lock 파일 --------
~$*.xlsx
~$*.xls
~$*.docx
~$*.doc
~$*.pptx

# -------- OS 시스템 파일 --------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.Spotlight-V100
.Trashes

# -------- IDE / 에디터 --------
.vscode/
.idea/
*.swp
*.swo
*~

# -------- Java / Gradle --------
.gradle/
**/build/
!**/src/**/build/
out/
bin/
*.class
hs_err_pid*
replay_pid*

# -------- 인프라 비밀 (TLS·env) --------
infrastructure/nginx/ssl/*.key
infrastructure/nginx/ssl/*.crt
infrastructure/nginx/ssl/*.pem
infrastructure/.env
infrastructure/.env.*
!infrastructure/.env.example

# -------- Python --------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/
.env

# -------- 임시·캐시·로그 --------
*.log
*.tmp
*.bak
.cache/
scripts/github-sync/0?-output.log
scripts/github-sync/*.log

# -------- Claude Code 런타임 --------
.claude/scheduled_tasks.lock
.claude/*.lock
